<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="管理者頁面"
            app:titleCentered="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <ImageView
        android:id="@+id/logo_image"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:adjustViewBounds="true"
        android:src="@drawable/roomrush"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout" />

    <TextView
        android:id="@+id/manage_system"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="管理系統"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textColor="@color/primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_image" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="48dp"
        app:layout_constraintTop_toBottomOf="@+id/manage_system">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/lesson_setting"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="課表管理"
            android:textSize="18sp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_today" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/classroom_setting"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="教室詳細設定"
            android:textSize="18sp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_preferences" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browse_classrooms_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="瀏覽教室狀態"
            android:textSize="18sp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_search" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/exit_button"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_marginBottom="48dp"
        android:text="離開"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>